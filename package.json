{
  "name": "full-city-columbus",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "export:drop001": "node tools/export-drop-assets.cjs",
    "generate:generic-qr": "node tools/generate-generic-qr-assets.cjs",
    "generate:printer-test-stickers": "node tools/generate-printer-test-stickers.cjs",
    "generate:qr-assets": "pnpm generate:generic-qr && pnpm generate:qr-posters && pnpm generate:sticker-sheets",
    "generate:qr-posters": "node tools/generate-standalone-qr-posters.cjs",
    "generate:sticker-sheets": "node tools/generate-sticker-sheets.cjs",
    "field-api:deploy": "wrangler deploy --config api/field-submission/wrangler.toml",
    "field-api:dry-run": "wrangler deploy --dry-run --config api/field-submission/wrangler.toml",
    "test:field-api": "node tools/pressure-test-field-api.cjs"
  },
  "devDependencies": {
    "pdf-lib": "^1.17.1",
    "sharp": "^0.35.3",
    "wrangler": "^4.107.1"
  }
}
